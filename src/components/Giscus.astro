---
// Component hiển thị bình luận Giscus
// Bạn cần thay thế các giá trị YOUR_... bằng cấu hình lấy từ https://giscus.app
---

<div class="mt-14 pt-8 border-t border-gray-100 dark:border-gray-800">
  <h2 class="text-xl font-semibold tracking-tight mb-6 text-gray-800 dark:text-gray-200">
    Bình luận
  </h2>
  <div class="giscus"></div>
</div>

<script type="text/partytown" src="https://giscus.app/client.js"
        data-repo="YOUR_GITHUB_USERNAME/YOUR_REPOSITORY"
        data-repo-id="YOUR_REPO_ID"
        data-category="Announcements"
        data-category-id="YOUR_CATEGORY_ID"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="preferred_color_scheme"
        data-lang="vi"
        crossorigin="anonymous">
</script>
