---
import Container from "@/components/container.astro";
import logoImage from "@/assets/logo.svg";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Themeswitch from "@/components/themeswitch.astro";
import { SITE_CONFIG } from "@/site.config";

interface Menu {
  label: string;
  href: string;
  external?: boolean;
  badge?: string;
}
const menuItems: Menu[] = [
  {
    label: "Trang chủ",
    href: "/",
  },
  {
    label: "Giới thiệu",
    href: "/about",
  },
  {
    label: "Danh mục",
    href: "/category",
  },

  {
    label: "Liên hệ",
    href: "/contact",
  },
];
---

<header
  id="navbar"
  class="sticky top-0 z-50 w-full bg-white/80 dark:bg-black/80 backdrop-blur-md transition-transform duration-300">
  <Container class="!py-3 lg:!py-4">
    <nav class="relative">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <a class="w-28" href="/">
            <Image src={logoImage} alt={SITE_CONFIG.siteName + " Logo"} loading="eager" fetchpriority="high" class="dark:brightness-0 dark:invert" />
          </a>
        </div>

        <div class="flex items-center gap-3">
          <Themeswitch />
          <a
            href="/search"
            aria-label="Search"
            class="p-2 text-gray-500 rounded-md hover:text-blue-500 dark:text-gray-300 dark:hover:text-blue-500">
            <Icon name="heroicons:magnifying-glass" class="w-6 h-6" />
          </a>

          <button
            id="menu"
            aria-label="Toggle Menu"
            class="px-2 py-1 text-gray-500 rounded-md focus:text-blue-500 focus:outline-none dark:text-gray-300">
            <svg
              class="w-6 h-6 fill-current"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24">
              <path
                class="navmenu-toggle"
                fill-rule="evenodd"
                d="M4 5h16a1 1 0 0 1 0 2H4a1 1 0 1 1 0-2zm0 6h16a1 1 0 0 1 0 2H4a1 1 0 0 1 0-2zm0 6h16a1 1 0 0 1 0 2H4a1 1 0 0 1 0-2z"
              ></path>

              <path
                class="navmenu-toggle hidden"
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M18.278 16.864a1 1 0 0 1-1.414 1.414l-4.829-4.828-4.828 4.828a1 1 0 0 1-1.414-1.414l4.828-4.829-4.828-4.828a1 1 0 0 1 1.414-1.414l4.829 4.828 4.828-4.828a1 1 0 1 1 1.414 1.414l-4.828 4.829 4.828 4.828z"
              ></path>
            </svg>
          </button>
        </div>
      </div>

      <div class="navmenu-toggle hidden">
        <div
          class="flex flex-col items-center justify-start mt-4 w-full md:hidden border-t border-gray-100 dark:border-gray-800 pt-2">
          {
            menuItems.map((item) => (
              <a
                href={item.href}
                class="w-full text-center py-2.5 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-blue-500"
                target={item.external ? "_blank" : ""}
                rel={item.external ? "noopener" : ""}>
                {item.label}
              </a>
            ))
          }
        </div>

        <div
          class="hidden md:flex md:flex-col absolute right-0 mt-2 w-48 bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 rounded-lg shadow-lg py-2 z-50">
          {
            menuItems.map((item) => (
              <a
                href={item.href}
                class="px-5 py-3 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-blue-500 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors"
                target={item.external ? "_blank" : ""}
                rel={item.external ? "noopener" : ""}>
                {item.label}
              </a>
            ))
          }
        </div>
      </div>
    </nav>
  </Container>
</header>

<script is:inline>
  const menuButton = document.getElementById("menu");
  menuButton.addEventListener("click", () => {
    [...document.querySelectorAll(".navmenu-toggle")].forEach((element) => {
      element.classList.toggle("hidden");
    });
  });

  let lastScrollTop = 0;
  const navbar = document.getElementById("navbar");

  window.addEventListener("scroll", () => {
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    if (scrollTop > lastScrollTop && scrollTop > 50) {
      // Scroll Down -> Hide
      navbar.classList.add("-translate-y-full");
    } else {
      // Scroll Up -> Show
      navbar.classList.remove("-translate-y-full");
    }
    lastScrollTop = scrollTop <= 0 ? 0 : scrollTop;
  });
</script>
