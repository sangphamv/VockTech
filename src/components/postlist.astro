---
import cx from "classnames";

import { Image, Picture } from "astro:assets";
import Label from "@/components/ui/label.astro";
import type { Author } from "@/data/authors";
import { authors } from "@/data/authors";
import { getFormattedDate } from "@/utils/all";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

const { post, aspect, preloadImage } = Astro.props;
const author = authors.find((item) => item.slug === post.data.author) as Author;
const allCategories = await getCollection("categories");
const categoryDoc = allCategories.find((item) => item.id === post.data.category);
const category = categoryDoc ? { slug: categoryDoc.id, ...categoryDoc.data } : null;

const slug = post.id.replace(/\.(md|mdx)$/, '');
const TitleTag = aspect === "landscape" ? "h2" : "h3";
---

<div class="cursor-pointer group relative">
  <div
    class={cx(
      "relative overflow-hidden transition-all duration-300 bg-gray-100 rounded-xl dark:bg-gray-800 group-hover:-translate-y-1 group-hover:shadow-xl group-hover:shadow-primary-500/20",
      "aspect-video"
    )}>
    <a href={"/danh-muc/" + post.data.category + "/" + slug}>
      {
        post.data.image ? (
          <Picture
            src={post.data.image}
            widths={[200, 400, 800]}
            sizes="(max-width: 640px) 90vw, 480px"
            formats={["avif"]}
            fallbackFormat="avif"
            alt={`Hình ảnh nổi bật cho bài viết: ${post.data.title}`}
            loading={preloadImage ? "eager" : "lazy"}
            fetchpriority={preloadImage ? "high" : "auto"}
            class="w-full h-full object-cover rounded-xl transition-transform duration-500 group-hover:scale-105"
          />
        ) : (
          <span class="absolute w-16 h-16 text-gray-200 -translate-x-1/2 -translate-y-1/2 top-1/2 left-1/2">
            <Icon
              class="w-4 h-4 text-black"
              name="heroicons:photo"
            />
          </span>
        )
      }
    </a>
  </div>

  {category && (
    <a href={"/danh-muc/" + category.slug}>
      <Label theme={category.color}>{category.title}</Label>
    </a>
  )}
  <TitleTag
    class="mt-2 text-lg font-semibold tracking-normal text-primary-600 dark:text-white">
    <a href={"/danh-muc/" + post.data.category + "/" + slug} class="before:absolute before:inset-0 before:z-10">
      <span
        class="bg-gradient-to-r from-primary-200 to-primary-100 dark:from-primary-800 dark:to-primary-900 bg-[length:0px_10px] bg-left-bottom bg-no-repeat transition-[background-size] duration-300 hover:bg-[length:100%_3px] group-hover:bg-[length:100%_10px]">
        {post.data.title}
      </span>
    </a>
  </TitleTag>

  {
    post.data.excerpt && (
      <p class="mt-2 text-sm text-gray-500 dark:text-gray-400 line-clamp-2">
        <a href={"/danh-muc/" + post.data.category + "/" + slug}>{post.data.excerpt}</a>
      </p>
    )
  }

  <div
    class="flex items-center mt-3 space-x-3 text-gray-500 dark:text-gray-400">
    <div class="flex items-center gap-3">
      <span class="text-sm">{author.name}</span>
    </div>
    <span class="text-xs text-gray-300 dark:text-gray-600"> &bull;</span>
    <time class="text-sm" datetime={post.data.publishDate.toISOString()}>
      {getFormattedDate(post.data.publishDate)}
    </time>
  </div>
</div>
