---
const { align = "center" } = Astro.props;
---

<div class:list={[
  "py-12 md:py-20 mb-10 md:mb-16",
  align === "center" ? "text-center flex flex-col items-center" : "text-left flex flex-col items-start"
]}>
  <h1
    class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-light-accent to-light-accent/70 dark:from-dark-accent dark:to-dark-accent/70 mb-4 px-4 pb-2">
    <slot name="title">Title</slot>
  </h1>
  <p class="text-lg md:text-xl text-light-foreground/70 dark:text-dark-foreground/70 max-w-2xl leading-relaxed px-4">
    <slot name="desc">Some description goes here</slot>
  </p>
</div>
