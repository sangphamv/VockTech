---
const { align = "center", isFullScreen = false } = Astro.props;
---

<div class:list={[
  "py-12 md:py-20 mb-10 md:mb-16 w-full bg-light-background dark:bg-dark-background bg-grid-black/[0.05] dark:bg-grid-white/[0.05] relative rounded-3xl",
  align === "center" ? "text-center flex flex-col items-center" : "text-left flex flex-col items-start",
  isFullScreen && "min-h-[85vh] justify-center"
]}>
  {/* Radial gradient mask */}
  <div class="absolute pointer-events-none inset-0 flex items-center justify-center bg-light-background dark:bg-dark-background [mask-image:radial-gradient(ellipse_at_center,transparent_50%,black)] rounded-3xl"></div>

  <div class="relative z-20 flex flex-col items-center w-full">
    <h1
      class="text-3xl sm:text-4xl md:text-5xl lg:text-7xl font-extrabold tracking-normal leading-[1.3] md:leading-[1.4] lg:leading-[1.4] text-transparent bg-clip-text bg-gradient-to-r from-light-accent to-light-accent/70 dark:from-dark-accent dark:to-dark-accent/70 mb-6 md:mb-8 px-4 pb-2">
      <slot name="title">Title</slot>
    </h1>
    <p class="text-base sm:text-lg md:text-xl text-light-foreground/70 dark:text-dark-foreground/70 max-w-2xl leading-relaxed px-4">
      <slot name="desc">Some description goes here</slot>
    </p>
  </div>
</div>
