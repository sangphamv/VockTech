---
const { page } = Astro.props;
---

{(page.url.prev || page.url.next) && (
  <div class="flex items-center justify-center mt-16 gap-4 sm:gap-8">
    {page.url.prev ? (
      <a href={page.url.prev} class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium whitespace-nowrap text-light-foreground/70 dark:text-dark-foreground/70 border border-light-surface/60 dark:border-dark-surface/60 rounded-full hover:border-light-foreground/30 dark:hover:border-dark-foreground/30 hover:bg-light-surface/10 dark:hover:bg-dark-surface/10 hover:text-light-foreground dark:hover:text-dark-foreground transition-all duration-300">
        &larr; Trang trước
      </a>
    ) : (
      <span aria-disabled="true" class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium whitespace-nowrap text-light-foreground/40 dark:text-dark-foreground/40 border border-light-surface/30 dark:border-dark-surface/30 rounded-full cursor-not-allowed">
        &larr; Trang trước
      </span>
    )}
    
    <span class="text-sm text-light-foreground/70 dark:text-dark-foreground/70 font-medium">
      {page.currentPage} / {page.lastPage}
    </span>
    
    {page.url.next ? (
      <a href={page.url.next} class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium whitespace-nowrap text-light-foreground/70 dark:text-dark-foreground/70 border border-light-surface/60 dark:border-dark-surface/60 rounded-full hover:border-light-foreground/30 dark:hover:border-dark-foreground/30 hover:bg-light-surface/10 dark:hover:bg-dark-surface/10 hover:text-light-foreground dark:hover:text-dark-foreground transition-all duration-300">
        Trang sau &rarr;
      </a>
    ) : (
      <span aria-disabled="true" class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium whitespace-nowrap text-light-foreground/40 dark:text-dark-foreground/40 border border-light-surface/30 dark:border-dark-surface/30 rounded-full cursor-not-allowed">
        Trang sau &rarr;
      </span>
    )}
  </div>
)}
