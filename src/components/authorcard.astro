---
import { Image } from "astro:assets";

const { author } = Astro.props;
---

<div
  data-pagefind-ignore="all"
  class="px-8 py-8 mt-3 text-light-foreground/70 rounded-2xl bg-transparent border border-light-surface dark:bg-dark-background dark:border-dark-surface dark:text-dark-foreground/70">
  <div class="flex flex-wrap items-start gap-3 sm:flex-nowrap sm:gap-6">
    <div class="relative flex-shrink-0 mt-1">
      {
        author.image && (
          <Image
            src={author.image}
            alt={`Ảnh chân dung chi tiết của tác giả ${author.name}`}
            width="96"
            height="96"
            format="avif"
            loading="lazy"
            decoding="async"
            class="rounded-full object-cover w-24 h-24"
          />
        )
      }
    </div>
    <div>
      <div>
        <p class="text-lg font-medium text-light-foreground dark:text-dark-foreground/70">
          Về {author.name}
        </p>
      </div>
      <div class="mt-3">
        {author.bio && <p>{author.bio}</p>}
      </div>
    </div>
  </div>
</div>
