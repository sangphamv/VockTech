---
import cx from "classnames";
---

<span
  class={cx(
    "inline-block mt-4 text-[11px] font-medium tracking-widest uppercase px-3 py-1 rounded-full",
    "border border-light-surface/60 dark:border-dark-surface/60 text-light-foreground/70 dark:text-dark-foreground/70",
    "hover:border-light-foreground/30 dark:hover:border-dark-foreground/30 hover:text-light-foreground dark:hover:text-dark-foreground hover:bg-light-surface/10 dark:hover:bg-dark-surface/10 transition-all duration-300"
  )}>
  <slot />
</span>
