---
export interface Props {
  headings: { depth: number; slug: string; text: string }[];
  isAccordion?: boolean;
}

const { headings, isAccordion = false } = Astro.props;
---

{
  headings.length > 0 &&
    (isAccordion ? (
      <div class="bg-transparent dark:bg-dark-surface/50 border border-light-surface dark:border-dark-surface rounded-xl mb-8 overflow-hidden">
        <button
          onclick="
            const content = this.nextElementSibling;
            content.classList.toggle('grid-rows-[0fr]');
            content.classList.toggle('grid-rows-[1fr]');
            this.querySelector('.arrow-icon').classList.toggle('rotate-180');
          "
          class="w-full flex justify-between items-center font-medium text-[15px] text-light-foreground dark:text-dark-foreground cursor-pointer p-4 select-none"
        >
          <span class="flex items-center gap-2 text-light-foreground/70 dark:text-dark-foreground/70">
            <svg
              class="w-5 h-5 text-light-foreground/70 dark:text-dark-foreground/70"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"
              />
            </svg>
            Mục lục
          </span>
          <span class="arrow-icon transition-transform duration-300 text-light-foreground/70 dark:text-dark-foreground/70">
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"
              />
            </svg>
          </span>
        </button>
        <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out">
          <div class="overflow-hidden">
            <div class="px-4 pb-4">
              <ul class="space-y-2 m-0 p-0 list-none pt-3 border-t border-light-surface dark:border-dark-surface/80">
                {headings.map((heading) => (
                  <li
                    class={`flex items-start leading-snug ${heading.depth === 3 ? "ml-4 pl-3 border-l border-light-surface dark:border-dark-surface text-[13px] text-light-foreground/60 dark:text-dark-foreground/60" : "text-[14px] text-light-foreground/80 dark:text-dark-foreground/80"}`}>
                    <a
                      href={`#${heading.slug}`}
                      class="hover:text-light-accent dark:hover:text-dark-accent transition-colors block py-0.5 w-full">
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    ) : (
      <nav class="toc-container">
        <h3 class="font-medium mb-4 text-light-foreground/70 dark:text-dark-foreground/70 uppercase tracking-wider text-sm">
          Mục lục
        </h3>
        <ul class="space-y-1 text-[13px] text-light-foreground/70 dark:text-dark-foreground/70">
          {headings.map((heading) => (
            <li
              class={`leading-snug ${heading.depth === 3 ? "ml-4 pl-3 border-l border-light-surface dark:border-dark-surface text-[12px] text-light-foreground/70 dark:text-dark-foreground/70 mt-1" : "text-light-foreground/70 dark:text-dark-foreground/70 mt-2"}`}>
              <a
                href={`#${heading.slug}`}
                class="hover:text-light-accent dark:hover:text-dark-accent dark:hover:text-dark-accent transition-colors block py-1">
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    ))
}
