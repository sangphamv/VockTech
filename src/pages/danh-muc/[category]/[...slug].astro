---
import { Image, Picture } from "astro:assets";
import Authorcard from "@/components/authorcard.astro";
import Container from "@/components/container.astro";
import Label from "@/components/ui/label.astro";
import { authors } from "@/data/authors";
import Layout from "@/layouts/Layout.astro";
import TOC from "@/components/TOC.astro";
import { getFormattedDate } from "@/utils/all";
import { type CollectionEntry, getCollection, render } from "astro:content";
import Postlist from "@/components/postlist.astro";
import { latestPosts } from "@/utils/content";
import ShareButtons from "@/components/ShareButtons.astro";
import Giscus from "@/components/Giscus.astro";
import Newsletter from "@/components/Newsletter.astro";

import type { Author } from "@/data/authors";

type Props = {
  post: CollectionEntry<"blog">;
};

export async function getStaticPaths() {
  const blog = await getCollection("blog");

  return blog.map((post) => ({
    params: {
      category: post.data.category,
      slug: post.id.replace(/\.(md|mdx)$/, ""),
    },
    props: { post },
  }));
}

const { post } = Astro.props;

const { Content, headings, remarkPluginFrontmatter } = await render(post);

const author = authors.find((item) => item.slug === post.data.author) as Author;
const allCategories = await getCollection("categories");
const categoryDoc = allCategories.find(
  (item) => item.id === post.data.category,
);
const category = categoryDoc
  ? { slug: categoryDoc.id, ...categoryDoc.data }
  : { slug: "", title: "", color: "blue", description: "" };

const relatedPosts = latestPosts
  .filter((p) => p.data.category === post.data.category && p.id !== post.id)
  .slice(0, 3);

const allPosts = await getCollection("blog");
const seriesPosts = post.data.series
  ? allPosts
      .filter((p) => p.data.series === post.data.series)
      .sort((a, b) => (a.data.seriesOrder || 0) - (b.data.seriesOrder || 0))
  : [];
---

<Layout
  title={post.data.title}
  description={post.data.excerpt}
  image={post.data.image.src}
  articleDate={post.data.publishDate}
  updatedDate={post.data.updatedDate}
  authorName={author.name}
  keywords={post.data.tags}
  faqs={remarkPluginFrontmatter.faqs}>
  
  <!-- Reading Progress Bar -->
  <div id="progress-bar" class="fixed top-0 left-0 h-1.5 bg-light-accent dark:bg-dark-accent z-[100] transition-all duration-150" style="width: 0%"></div>
  <Container>
    <div class="max-w-screen-lg mx-auto">
      <div class="text-center">
        <a href={"/danh-muc/" + category.slug}>
          <Label
            theme={category.color as
              | "green"
              | "blue"
              | "orange"
              | "purple"
              | "pink"}>{category.title}</Label
          >
        </a>
      </div>

      <nav aria-label="Breadcrumb" class="flex justify-center mt-5 mb-2">
        <ol
          class="flex flex-wrap justify-center items-center gap-x-2 gap-y-1 text-sm text-light-foreground/70 dark:text-dark-foreground/70">
          <li class="whitespace-nowrap">
            <a
              href="/"
              class="hover:text-light-accent dark:hover:text-dark-accent dark:hover:text-dark-accent transition-colors"
              >Trang chủ</a
            >
          </li>
          <li class="whitespace-nowrap">
            <span class="mx-0.5">/</span>
          </li>
          <li class="whitespace-nowrap">
            <a
              href="/danh-muc"
              class="hover:text-light-accent dark:hover:text-dark-accent dark:hover:text-dark-accent transition-colors"
              >Danh mục</a
            >
          </li>
          <li class="whitespace-nowrap">
            <span class="mx-0.5">/</span>
          </li>
          <li class="whitespace-nowrap">
            <a
              href={`/danh-muc/${category.slug}`}
              class="hover:text-light-accent dark:hover:text-dark-accent dark:hover:text-dark-accent transition-colors"
              >{category.title}</a
            >
          </li>
          <li class="whitespace-nowrap">
            <span class="mx-0.5">/</span>
          </li>
          <li
            class="text-light-foreground dark:text-dark-foreground/90 font-medium truncate max-w-[150px] sm:max-w-xs"
            aria-current="page"
            title={post.data.title}>
            {post.data.title}
          </li>
        </ol>
      </nav>

      <h1
        class="mt-2 mb-3 text-3xl md:text-4xl lg:text-5xl font-bold tracking-normal text-center leading-tight md:leading-snug text-light-accent dark:text-dark-accent">
        {post.data.title}
      </h1>

      <div class="flex justify-center mt-3 space-x-3 text-light-foreground/70">
        <div class="flex items-center gap-3">
          <div class="relative flex-shrink-0">
            {
              author.image && (
                <Image
                  src={author.image as any}
                  alt={`Ảnh đại diện tác giả ${author.name}`}
                  width={80}
                  height={80}
                  format="avif"
                  loading="eager"
                  fetchpriority="high"
                  class="rounded-full object-cover w-10 h-10"
                />
              )
            }
          </div>

          <div>
            <p class="text-light-foreground dark:text-dark-foreground/70">
              {author.name}
            </p>
            <div class="flex flex-wrap items-center space-x-2 text-sm gap-y-1">
              <time
                class="text-light-foreground/70 dark:text-dark-foreground/70"
                datetime={post.data.publishDate.toISOString()}>
                {getFormattedDate(post.data.publishDate)}
              </time>
              {
                post.data.updatedDate &&
                  post.data.updatedDate.getTime() >
                    post.data.publishDate.getTime() && (
                    <>
                      <span class="text-light-foreground/50 dark:text-dark-foreground/50 hidden sm:inline">
                        •
                      </span>
                      <time
                        class="text-light-foreground/70 dark:text-dark-foreground/70"
                        datetime={post.data.updatedDate.toISOString()}>
                        Cập nhật: {getFormattedDate(post.data.updatedDate)}
                      </time>
                    </>
                  )
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>

  <div
    class="relative z-0 w-full max-w-[800px] mx-auto overflow-hidden lg:rounded-lg aspect-video">
    {
      post.data.image && (
        <Picture
          src={post.data.image}
          widths={[768, 1024]}
          sizes="(max-width: 800px) 100vw, 1024px"
          width={1024}
          height={576}
          formats={["avif"]}
          fallbackFormat="avif"
          quality={80}
          alt={post.data.title}
          loading="eager"
          fetchpriority="high"
          class="w-full h-full object-cover"
        />
      )
    }
  </div>

  <Container>
    <div
      class="grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_minmax(auto,800px)_minmax(0,1fr)] gap-8 max-w-screen-xl mx-auto">
      <!-- Cột trái (để trống nhằm căn giữa bài viết) -->
      <div class="hidden xl:block"></div>

      <!-- Cột giữa (bài viết) -->
      <article
        class="w-full min-w-0"
        data-pagefind-body
        data-pagefind-filter={`Thể loại:${category.title}`}>
        {
          post.data.image && (
            <meta
              data-pagefind-meta="image[content]"
              content={post.data.image.src}
            />
          )
        }

        <div
          class="mx-auto my-6 prose md:prose-lg dark:prose-invert prose-headings:font-bold prose-img:rounded-xl prose-img:shadow-md prose-img:aspect-video prose-img:w-full prose-img:object-cover prose-img:mx-auto w-full max-w-[70ch]">
          {
            seriesPosts.length > 0 && (
              <div class="bg-transparent dark:bg-dark-surface/50 border border-light-surface dark:border-dark-surface rounded-xl mb-8 not-prose overflow-hidden">
                <button
                  onclick="
                  const content = this.nextElementSibling;
                  content.classList.toggle('grid-rows-[0fr]');
                  content.classList.toggle('grid-rows-[1fr]');
                  this.querySelector('.arrow-icon').classList.toggle('rotate-180');
                "
                  class="w-full flex justify-between items-center font-medium text-[15px] text-light-foreground dark:text-dark-foreground cursor-pointer p-4">
                  <span class="flex items-center gap-2 text-light-foreground/70 dark:text-dark-foreground/70">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-5 w-5 text-light-foreground/70 dark:text-dark-foreground/70"
                      viewBox="0 0 20 20"
                      fill="currentColor">
                      <path d="M5 4a2 2 0 012-2h6a2 2 0 012 2v14l-5-2.5L5 18V4z" />
                    </svg>
                    Series: {post.data.series}
                  </span>
                  <span class="arrow-icon transition-transform duration-300 text-light-foreground/70 dark:text-dark-foreground/70">
                    <svg
                      class="w-5 h-5"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      xmlns="http://www.w3.org/2000/svg">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  </span>
                </button>
                <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out">
                  <div class="overflow-hidden">
                    <div class="px-4 pb-4">
                      <ul class="space-y-2 m-0 p-0 list-none pt-3 border-t border-light-surface dark:border-dark-surface/80">
                        {seriesPosts.map((sp, index) => (
                          <li class="flex items-start gap-2.5 text-[14px] leading-snug">
                            <span class="flex-shrink-0 w-5 h-5 rounded-full bg-light-surface/50/60 dark:bg-dark-surface/80/50 text-light-foreground/70 dark:text-dark-foreground/70 flex items-center justify-center text-[11px] font-medium mt-0.5">
                              {index + 1}
                            </span>
                            {sp.id === post.id ? (
                              <span class="text-light-foreground dark:text-dark-foreground font-medium">
                                {sp.data.title}{" "}
                                <span class="text-sm font-normal text-light-foreground/70 dark:text-dark-foreground/70 ml-1">
                                  (Bài hiện tại)
                                </span>
                              </span>
                            ) : (
                              <a
                                href={`/danh-muc/${category.slug}/${sp.id.replace(/\.(md|mdx)$/, "")}`}
                                class="text-light-foreground/70 dark:text-dark-foreground/70 hover:text-light-foreground dark:hover:text-dark-foreground transition-colors">
                                {sp.data.title}
                              </a>
                            )}
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                </div>
              </div>
            )
          }

          <div class="not-prose">
            <TOC
              headings={headings.filter((h) => h.depth === 2 || h.depth === 3)}
              isAccordion={true}
            />
          </div>

          <Content />

          <div class="flex flex-wrap items-center w-full gap-3 md:w-auto mt-10">
            {
              post.data.tags.map((tag) => (
                <a
                  href={`/tags/${tag}`}
                  class="text-sm text-light-foreground/70 hover:text-light-accent dark:hover:text-dark-accent dark:text-dark-foreground/70 dark:hover:text-dark-accent">
                  #{tag}
                </a>
              ))
            }
          </div>

          <ShareButtons title={post.data.title} url={Astro.url.href} />
        </div>

        {author && <Authorcard author={author} />}

        <Newsletter />
        <Giscus />
      </article>
    </div>
  </Container>

  {
    relatedPosts.length > 0 && (
      <Container class="mt-14 pb-14">
        <div class="border-t border-light-surface dark:border-dark-surface pt-10">
          <h2 class="text-2xl font-bold tracking-tight mb-8 dark:text-dark-foreground text-center">
            Bài viết liên quan
          </h2>
          <div class="grid gap-10 lg:gap-10 md:grid-cols-2 xl:grid-cols-3">
            {relatedPosts.map((relatedPost) => (
              <Postlist post={relatedPost} aspect="square" />
            ))}
          </div>
        </div>
      </Container>
    )
  }

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      // Reading Progress Bar
      const progressBar = document.getElementById('progress-bar');
      if (progressBar) {
        window.addEventListener('scroll', () => {
          const scrollTop = document.documentElement.scrollTop || document.body.scrollTop;
          const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          if (scrollHeight > 0) {
            const progress = (scrollTop / scrollHeight) * 100;
            progressBar.style.width = progress + '%';
          }
        }, { passive: true });
      }
    });
  </script>
</Layout>
