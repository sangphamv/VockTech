---
import Container from "@/components/container.astro";
import Postlist from "@/components/postlist.astro";
import Layout from "@/layouts/Layout.astro";
import { latestPosts } from "@/utils/content";
import { SITE_CONFIG } from "@/site.config";
import Pagination from "@/components/Pagination.astro";

import type { PaginateFunction } from "astro";

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  return paginate(latestPosts, { pageSize: 8 });
}

const { page } = Astro.props;
---

<Layout title="">
  <Container>
    <main>
      <h1 class="sr-only">Trang chủ {SITE_CONFIG.siteName}</h1>
      
      <>
        <div class="grid gap-10 lg:gap-10 md:grid-cols-2">
          {
            page.data
              .slice(0, 2)
              .map((post: any) => (
                <Postlist post={post} aspect="landscape" preloadImage={true} />
              ))
          }
        </div>
        <div class="grid gap-10 mt-10 lg:gap-10 md:grid-cols-2 xl:grid-cols-3">
          {
            page.data
              .slice(2)
              .map((post: any, index: number) => <Postlist post={post} aspect="square" preloadImage={index < 3} />)
          }
        </div>
      </>

      <Pagination page={page} />
    </main>
  </Container>
</Layout>
