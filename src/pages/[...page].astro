---
import Container from "@/components/container.astro";
import Postlist from "@/components/postlist.astro";
import Layout from "@/layouts/Layout.astro";
import { latestPosts } from "@/utils/content";
import { SITE_CONFIG } from "@/site.config";
import Pagination from "@/components/Pagination.astro";

import type { PaginateFunction } from "astro";

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  return paginate(latestPosts, { pageSize: 8 });
}

const { page } = Astro.props;
---

<Layout title="">
  <Container>
    <main id="main-content">
      {page.currentPage === 1 && (
        <div class="min-h-[85vh] flex flex-col items-center justify-center text-center mb-24 md:mb-32">
          <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-gray-900 dark:text-white mb-6">
            Khám phá <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-500 to-purple-500">Thủ Thuật Công Nghệ</span> Đỉnh Cao
          </h1>
          <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-2xl mb-10">
            Cập nhật những xu hướng mới nhất, đánh giá sản phẩm khách quan và chia sẻ kinh nghiệm công nghệ thực tiễn dành riêng cho bạn.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto justify-center px-4 sm:px-0">
            <a href="#latest-posts" class="w-full sm:w-auto px-8 py-3.5 bg-primary-600 text-white font-medium rounded-xl hover:bg-primary-700 transition-all shadow-sm hover:shadow-lg hover:-translate-y-1 duration-300 text-center">Đọc bài mới nhất</a>
            <a href="/danh-muc" class="w-full sm:w-auto px-8 py-3.5 border-2 border-gray-200 dark:border-gray-800 text-gray-900 dark:text-white font-medium rounded-xl hover:border-primary-500 hover:text-primary-600 dark:hover:border-primary-500 dark:hover:text-primary-400 transition-all duration-300 text-center">Khám phá danh mục</a>
          </div>
        </div>
      )}
      {page.currentPage > 1 && (
        <h1 class="sr-only">Trang {page.currentPage} - Trang chủ {SITE_CONFIG.siteName}</h1>
      )}
      
      <>
        <div class="mb-8 flex items-center justify-between">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-white">
            <span class="relative inline-block">
              {page.currentPage === 1 ? "Bài viết nổi bật" : `Tất cả bài viết - Trang ${page.currentPage}`}
              <span class="absolute -bottom-2 left-0 w-1/2 h-1.5 bg-primary-500 rounded-full"></span>
            </span>
          </h2>
        </div>

        <div id="latest-posts" class="grid gap-10 lg:gap-10 md:grid-cols-2 scroll-mt-24">
          {
            page.data
              .slice(0, 2)
              .map((post: any) => (
                <Postlist post={post} aspect="landscape" preloadImage={page.currentPage > 1} />
              ))
          }
        </div>

        {page.data.length > 2 && (
          <>
            {page.currentPage === 1 && (
              <div class="mt-16 mb-8 flex items-center justify-between">
                <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-white">
                  <span class="relative inline-block">
                    Mới cập nhật
                    <span class="absolute -bottom-2 left-0 w-1/2 h-1.5 bg-primary-500 rounded-full"></span>
                  </span>
                </h2>
              </div>
            )}
            <div class={page.currentPage === 1 ? "grid gap-10 lg:gap-10 md:grid-cols-2 xl:grid-cols-3" : "grid gap-10 mt-10 lg:gap-10 md:grid-cols-2 xl:grid-cols-3"}>
              {
                page.data
                  .slice(2)
                  .map((post: any) => <Postlist post={post} aspect="square" preloadImage={false} />)
              }
            </div>
          </>
        )}
      </>

      <Pagination page={page} />
    </main>
  </Container>
</Layout>
