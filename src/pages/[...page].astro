---
import Container from "@/components/container.astro";
import Postlist from "@/components/postlist.astro";
import Layout from "@/layouts/Layout.astro";
import { latestPosts } from "@/utils/content";
import { SITE_CONFIG } from "@/site.config";
import Pagination from "@/components/Pagination.astro";

import type { PaginateFunction } from "astro";

export async function getStaticPaths({
  paginate,
}: {
  paginate: PaginateFunction;
}) {
  return paginate(latestPosts, { pageSize: 8 });
}

const { page } = Astro.props;
---

<Layout title="">
  <Container>
    <main id="main-content">
      {
        page.currentPage === 1 && (
          <div class="min-h-[85vh] w-full bg-light-background dark:bg-dark-background bg-grid-black/[0.05] dark:bg-grid-white/[0.05] relative flex flex-col items-center justify-center text-center mb-16 md:mb-32">
            {/* Radial gradient mask */}
            <div class="absolute pointer-events-none inset-0 flex items-center justify-center bg-light-background dark:bg-dark-background [mask-image:radial-gradient(ellipse_at_center,transparent_50%,black)]" />

            <div class="relative z-20 w-full max-w-4xl mx-auto flex flex-col items-center">
              <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-7xl font-extrabold tracking-normal leading-[1.3] md:leading-[1.4] lg:leading-[1.4] text-light-foreground dark:text-dark-foreground mb-6 md:mb-8">
                Cập nhật xu hướng{" "}
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-light-accent to-light-accent/70 dark:from-dark-accent dark:to-dark-accent/70">
                  Công nghệ & AI
                </span>{" "}
                thực chiến
              </h1>
              <p class="text-base sm:text-lg md:text-xl leading-relaxed text-light-foreground/70 dark:text-dark-foreground/70 max-w-2xl mb-8 md:mb-12">
                Kiến thức chuyên sâu và giải pháp tối ưu giúp bạn làm chủ kỷ nguyên&nbsp;số.
              </p>
              <div class="flex flex-col sm:flex-row gap-3 md:gap-4 justify-center">
                <a
                  href="#latest-posts"
                  class="w-full sm:w-auto px-6 py-3 md:px-8 md:py-3.5 bg-light-accent dark:bg-dark-accent text-white text-[19px] dark:text-dark-background font-bold rounded-xl hover:bg-light-accent/90 dark:hover:bg-dark-accent/90 transition-all shadow-sm hover:shadow-lg hover:-translate-y-1 duration-300 text-center">
                  Đọc bài mới nhất
                </a>
                <a
                  href="/danh-muc"
                  class="w-full sm:w-auto px-6 py-3 md:px-8 md:py-3.5 border-2 border-light-surface dark:border-dark-surface bg-transparent text-light-foreground dark:text-dark-foreground text-[19px] font-bold rounded-xl hover:border-light-accent dark:hover:border-dark-accent hover:text-light-accent dark:hover:text-dark-accent transition-all duration-300 text-center">
                  Khám phá danh mục
                </a>
              </div>
            </div>
          </div>
        )
      }
      {
        page.currentPage > 1 && (
          <h1 class="sr-only">
            Trang {page.currentPage} - Trang chủ {SITE_CONFIG.siteName}
          </h1>
        )
      }

      {
        page.currentPage === 1 ? (
          <div class="bg-light-surface/30 dark:bg-dark-surface/50 py-12 px-6 sm:px-10 -mx-6 sm:-mx-10 rounded-3xl mb-16">
            <div class="mb-8 flex items-center justify-between">
              <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-light-foreground dark:text-dark-foreground">
                <span class="relative inline-block">
                  Bài viết nổi bật
                  <span class="absolute -bottom-2 left-0 w-1/2 h-1.5 bg-light-accent dark:bg-dark-accent rounded-full" />
                </span>
              </h2>
            </div>
            <div
              id="latest-posts"
              class="grid gap-10 lg:gap-10 md:grid-cols-2 scroll-mt-24">
              {page.data.slice(0, 2).map((post: any) => (
                <Postlist post={post} aspect="landscape" preloadImage={false} />
              ))}
            </div>
          </div>
        ) : (
          <>
            <div class="mb-8 flex items-center justify-between">
              <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-light-foreground dark:text-dark-foreground">
                <span class="relative inline-block">
                  Tất cả bài viết - Trang {page.currentPage}
                  <span class="absolute -bottom-2 left-0 w-1/2 h-1.5 bg-light-accent dark:bg-dark-accent rounded-full" />
                </span>
              </h2>
            </div>
            <div
              id="latest-posts"
              class="grid gap-10 lg:gap-10 md:grid-cols-2 scroll-mt-24">
              {page.data.slice(0, 2).map((post: any) => (
                <Postlist post={post} aspect="landscape" preloadImage={false} />
              ))}
            </div>
          </>
        )
      }

      {
        page.data.length > 2 && (
          <>
            {page.currentPage === 1 && (
              <div class="mt-16 mb-8 flex items-center justify-between">
                <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-light-foreground dark:text-dark-foreground">
                  <span class="relative inline-block">
                    Mới cập nhật
                    <span class="absolute -bottom-2 left-0 w-1/2 h-1.5 bg-light-accent dark:bg-dark-accent rounded-full" />
                  </span>
                </h2>
              </div>
            )}
            <div
              class={
                page.currentPage === 1
                  ? "grid gap-10 lg:gap-10 md:grid-cols-2 xl:grid-cols-3"
                  : "grid gap-10 mt-10 lg:gap-10 md:grid-cols-2 xl:grid-cols-3"
              }>
              {page.data.slice(2).map((post: any) => (
                <Postlist post={post} aspect="square" preloadImage={false} />
              ))}
            </div>
          </>
        )
      }
    </main>

    <Pagination page={page} />

    {
      page.currentPage === 1 && (
        <div class="mt-20 mb-10 bg-light-accent/10 dark:bg-dark-accent/10 border border-light-accent/20 dark:border-dark-accent/20 rounded-3xl p-8 md:p-12 text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-light-foreground dark:text-dark-foreground mb-4">
            Bạn muốn đọc thêm?
          </h2>
          <p class="text-lg text-light-foreground/70 dark:text-dark-foreground/70 mb-8 max-w-2xl mx-auto">
            Khám phá toàn bộ kho tàng kiến thức của chúng tôi với hàng trăm bài
            viết về công nghệ và lập trình.
          </p>
          <a
            href="/danh-muc"
            class="inline-block px-10 py-4 bg-light-accent dark:bg-dark-accent text-white text-[19px] dark:text-dark-background font-bold rounded-xl hover:bg-light-accent/90 dark:hover:bg-dark-accent/90 transition-all shadow-sm hover:shadow-lg hover:-translate-y-1 duration-300">
            Khám phá tất cả
          </a>
        </div>
      )
    }
  </Container>
</Layout>
