---
import { AstroFont } from 'astro-font';

import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar.astro";
import SEO from "@/components/SEO.astro";
import { SITE_CONFIG } from "@/site.config";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  articleDate?: string | Date;
  updatedDate?: string | Date;
  authorName?: string;
  keywords?: string[];
  faqs?: { question: string; answer: string }[];

  // Backwards compatibility (existing pages)
  desc?: string;
  ogimage?: string;
}

const { title, description, image, articleDate, updatedDate, authorName, keywords, faqs, desc, ogimage } = Astro.props;

const resolvedDescription = description ?? desc;
const resolvedImage = image ?? ogimage;
---

<!DOCTYPE html>
<html lang={SITE_CONFIG.lang} class="scroll-smooth scroll-pt-16">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <meta name="generator" content={Astro.generator} />
    {SITE_CONFIG.analytics?.searchConsole?.enabled && SITE_CONFIG.analytics?.searchConsole?.metaVerification && (
      <meta name="google-site-verification" content={SITE_CONFIG.analytics.searchConsole.metaVerification} />
    )}
    <AstroFont
      config={[
        {
          name: "Inter",
          src: [
            {
              style: 'normal',
              weight: '100 900',
              path: '/fonts/inter-latin-wght-normal.woff2',
            },
            {
              style: 'normal',
              weight: '100 900',
              path: '/fonts/inter-vietnamese-wght-normal.woff2',
            },
          ],
          preload: true,
          display: "swap",
          selector: "body",
          fallback: "sans-serif",
        },
      ]}
    />
    <!-- Preconnect hints cho các third-party origins (Giscus) -->
    <link rel="preconnect" href="https://giscus.app" crossorigin />
    <link rel="preconnect" href="https://api.github.com" crossorigin />
    <link rel="alternate" type="application/rss+xml" title={SITE_CONFIG.title} href="/rss.xml" />
    <SEO
      title={title}
      description={resolvedDescription}
      image={resolvedImage}
      articleDate={articleDate}
      updatedDate={updatedDate}
      authorName={authorName}
      keywords={keywords}
      faqs={faqs}
    />
    <script is:inline>
      const getTheme = () => {
        if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
          const theme = localStorage.getItem("theme");
          if (theme === "system") {
            return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
          }
          return theme;
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      };

      if (getTheme() === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body class="antialiased text-light-foreground bg-light-background dark:bg-dark-background dark:text-dark-foreground/70 selection:bg-light-accent/20 selection:text-light-foreground dark:selection:bg-dark-accent/20 dark:selection:text-dark-foreground">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 z-[100] px-4 py-2 bg-light-accent dark:bg-dark-accent text-white text-[19px] dark:text-dark-background font-bold rounded-md">Chuyển đến nội dung chính</a>
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
      /* Custom Scrollbar */
      ::-webkit-scrollbar {
        width: 10px;
        height: 10px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: rgba(156, 163, 175, 0.5);
        border-radius: 8px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: rgba(107, 114, 128, 0.8);
      }
      html {
        color-scheme: light;
      }
      html.dark {
        color-scheme: dark;
      }
      .theme-transition,
      .theme-transition *,
      .theme-transition *::before,
      .theme-transition *::after {
        transition-property: background-color, border-color, color, fill, stroke !important;
        transition-duration: 300ms !important;
        transition-timing-function: ease-in-out !important;
      }
      .astro-code {
        position: relative;
      }
      .copy-code-btn {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        padding: 0.375rem;
        color: #9ca3af;
        background-color: transparent;
        border: none;
        border-radius: 0.375rem;
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.3s, color 0.3s, background-color 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .astro-code:hover .copy-code-btn,
      .copy-code-btn:focus-visible {
        opacity: 1;
      }
      .copy-code-btn:hover {
        color: #f3f4f6;
        background-color: rgba(255, 255, 255, 0.1);
      }
      

    </style>
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const blocks = document.querySelectorAll("pre.astro-code");
        const copyIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
        const copiedIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #4ade80"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
        
        blocks.forEach((block) => {
          const button = document.createElement("button");
          button.className = "copy-code-btn";
          button.innerHTML = copyIcon;
          button.setAttribute("aria-label", "Copy code");
          button.setAttribute("title", "Copy code");
          block.appendChild(button);

          button.addEventListener("click", () => {
            const code = block.querySelector("code")?.innerText;
            if (code) {
              navigator.clipboard.writeText(code).then(() => {
                button.innerHTML = copiedIcon;
                setTimeout(() => {
                  button.innerHTML = copyIcon;
                }, 2000);
              });
            }
          });
        });
      });
    </script>
    <script is:inline>
      // Add title to partytown or dynamically injected iframes for accessibility
      document.addEventListener("DOMContentLoaded", () => {
        const observer = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            mutation.addedNodes.forEach((node) => {
              if (node.nodeName === 'IFRAME' && !node.hasAttribute('title')) {
                node.setAttribute('title', 'Partytown Worker');
                node.setAttribute('aria-hidden', 'true');
                if (!node.hasAttribute('loading')) node.setAttribute('loading', 'lazy');
              } else if (node.querySelectorAll) {
                node.querySelectorAll('iframe:not([title])').forEach(iframe => {
                  iframe.setAttribute('title', 'Partytown Worker');
                  iframe.setAttribute('aria-hidden', 'true');
                  if (!iframe.hasAttribute('loading')) iframe.setAttribute('loading', 'lazy');
                });
              }
            });
          });
        });
        observer.observe(document.body, { childList: true, subtree: true });
      });
    </script>
  </body>
</html>
